#!/bin/sh
set -e
case "$1" in
  remove|deconfigure)
    if command -v systemctl >/dev/null 2>&1; then
      systemctl stop vcactl.service >/dev/null 2>&1 || true
      systemctl disable vcactl.service >/dev/null 2>&1 || true
    fi
    [ ! -L /usr/sbin/vcactrl ] || rm -f /usr/sbin/vcactrl
    ;;
esac
exit 0
